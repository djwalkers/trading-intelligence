# Build 1.13.0 — configuration validation summary
#
# None of the variables below are required for the app to run — it's designed to work fully
# standalone with zero env vars (local prototype mode: mock market data, browser-storage
# persistence, no auth). Every variable is validated at startup by src/lib/config/client-config.ts
# (client-safe values, NEXT_PUBLIC_-prefixed) or src/lib/config/server-config.ts (server-only
# values — ALPHA_VANTAGE_API_KEY, SUPABASE_SERVICE_ROLE_KEY, WORKER_POLL_INTERVAL_MS). Validation
# fails loudly (throws a clear error naming the problem, never silently falls back) in exactly
# two cases: (1) one half of a required pair is set without its partner — NEXT_PUBLIC_SUPABASE_URL
# without NEXT_PUBLIC_SUPABASE_ANON_KEY (or vice versa), SUPABASE_SERVICE_ROLE_KEY without
# NEXT_PUBLIC_SUPABASE_URL, or NEXT_PUBLIC_MARKET_DATA_PROVIDER without
# NEXT_PUBLIC_MARKET_DATA_API_KEY (or vice versa); (2) a value is present but malformed — e.g.
# NEXT_PUBLIC_SUPABASE_URL that isn't a valid URL, or WORKER_POLL_INTERVAL_MS that isn't a positive
# integer. Fully unset is always valid; fully set (a matched pair, correctly formed) is always
# valid — only an inconsistent in-between state is treated as a configuration error.
#
# Quick reference — every variable below, required vs optional, server-only vs client-exposed:
#
#   NEXT_PUBLIC_SUPABASE_URL          optional, paired  client-exposed (public by design)
#   NEXT_PUBLIC_SUPABASE_ANON_KEY     optional, paired  client-exposed (public by design)
#   SUPABASE_SERVICE_ROLE_KEY         optional, paired  server-only, never bundled to the browser
#   WORKER_POLL_INTERVAL_MS           optional          server-only (worker process only)
#   NEXT_PUBLIC_MARKET_DATA_PROVIDER  optional, paired  client-exposed (a display label only)
#   NEXT_PUBLIC_MARKET_DATA_API_KEY   optional, paired  client-exposed (sent from the browser)
#   ALPHA_VANTAGE_API_KEY             optional          server-only, never bundled to the browser
#   MARKET_SCREENING_ROLLOUT_STAGE    optional          server-only (worker process only)
#   RESEARCH_RUNS_DIRECTORY           optional          server-only (import-research-run CLI only)
#   HERMES_STRATEGY_REGISTRY_PATH     optional          server-only (Hermes execution pipeline only)
#   EXECUTION_MODE                    optional          server-only (Hermes execution pipeline only)
#   DEMO_EXECUTION_MODE               optional          server-only (Hermes execution pipeline only)
#   HERMES_PAPER_STARTING_CASH        optional          server-only (Hermes execution pipeline only)
#   HERMES_MAX_OPEN_POSITIONS         optional          server-only (Hermes execution pipeline only)
#   BROKER_PROVIDER                   optional          server-only (Hermes execution pipeline only)
#   HERMES_MARKET_DATA_PROVIDER       optional          server-only (Hermes execution pipeline only)
#   HYPERLIQUID_TESTNET_PRIVATE_KEY   optional, paired  server-only, NEVER bundled/logged/committed
#   HYPERLIQUID_TESTNET_ACCOUNT_ADDRESS optional, paired server-only (Hermes execution pipeline only)
#   HYPERLIQUID_TESTNET_EXECUTION_ENABLED optional       server-only (Hermes execution pipeline only)
#   HYPERLIQUID_TESTNET_MAX_ORDER_VALUE_USD optional     server-only (Hermes execution pipeline only)
#   HYPERLIQUID_TESTNET_INSTRUMENT    optional          server-only (Hermes execution pipeline only)
#   TRADING212_API_KEY                optional, req'd*  server-only, NEVER bundled/logged/committed
#   TRADING212_API_SECRET             optional, req'd*  server-only, NEVER bundled/logged/committed
#   TRADING212_DEMO_EXECUTION_ENABLED optional          server-only (Hermes execution pipeline only)
#   TRADING212_DEMO_INSTRUMENT        optional          server-only (Hermes execution pipeline only)
#   TRADING212_DEMO_TEST_QUANTITY     optional          server-only (Hermes execution pipeline only)
#   (*required only when BROKER_PROVIDER=trading212-demo)
#   ETORO_API_KEY                     optional, req'd**  server-only, NEVER bundled/logged/committed
#   ETORO_USER_KEY                    optional, req'd**  server-only, NEVER bundled/logged/committed
#   ETORO_ENV                         optional, req'd**  server-only (Hermes execution pipeline only)
#   ETORO_DEMO_TEST_INSTRUMENT        optional          server-only (Hermes execution pipeline only)
#   ETORO_DEMO_TEST_AMOUNT            optional, req'd**  server-only (Hermes execution pipeline only)
#   (**required only when BROKER_PROVIDER=etoro-demo)

# Supabase (optional — not required to run this app)
#
# As of Build 0.9.0, setting these switches paper trade persistence from local browser storage to
# a real Supabase project. As of Build 1.1.0, setting these ALSO turns on Supabase Auth and gates
# every page in the app behind sign-in — paper trades become scoped to the signed-in user via
# Row Level Security. See docs/database/SUPABASE-SETUP.md for setup steps (including two new
# migrations, 0006 and 0007, required for user-scoped trades) and docs/product/BUILD-1.1.0.md for
# what changed.
#
# To try this out: copy this file to .env.local and fill in values from your Supabase project
# settings (Settings -> API), then run ALL SEVEN migrations in supabase/migrations/ (not just the
# first five from Build 0.7.0). System Health will then show "Auth: Enabled" and prompt you to
# sign up / sign in.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (optional — not required to run the browser app; required to run the
# Mission 8 worker, `npm run worker`)
#
# Prepared as unused infrastructure in Mission 6; as of Mission 8, this is what the background
# worker (`npm run worker`, src/worker/) actually uses to read schedules and write scans on a
# user's behalf without a browser session. The browser app never reads this key. Deliberately NOT
# prefixed with NEXT_PUBLIC_, so Next.js never inlines it into the browser bundle; only read by
# src/lib/supabase/service-role-client.ts, which is marked "server-only" so importing it from a
# client component fails the build. This key bypasses Row Level Security entirely — see
# docs/product/MISSION-6-SERVER-ARCHITECTURE-PREPARATION.md, "Service-role safety", and
# docs/product/MISSION-8-VPS-WORKER.md, "Authentication", before running the worker against a real
# project. Get it from your Supabase project settings (Settings -> API -> service_role secret) —
# never commit it, never share it in a browser context, never log it.
SUPABASE_SERVICE_ROLE_KEY=

# Worker poll interval, in milliseconds (optional — Mission 8; defaults to 30000 / 30 seconds if
# unset). How often `npm run worker` wakes up to check for due schedules — not the scan interval
# itself (that's bot_schedules.interval_minutes, per user). Only relevant when running the worker.
# Build 1.13.0 — validated as a positive integer (minimum 1000) at worker startup; a malformed
# value (e.g. non-numeric) now fails loudly instead of silently becoming NaN.
WORKER_POLL_INTERVAL_MS=

# Market data (optional — not required to run this app)
#
# As of Build 1.0.0, setting both of these switches instrument pricing from mock data to a live
# external provider. Without them, the app runs entirely on mock prices — this is the default and
# fully supported. See docs/product/BUILD-1.0.0.md for the provider architecture.
#
# NEXT_PUBLIC_MARKET_DATA_PROVIDER is a label only (e.g. "Finnhub") shown in System Health and the
# Dashboard Market Data Status card — it does not select between multiple vendor integrations.
# NEXT_PUBLIC_MARKET_DATA_API_KEY is sent to Finnhub's public quote endpoint
# (https://finnhub.io/docs/api/quote), the concrete adapter implemented in
# src/lib/market-data/external-market-data-provider.ts. If the external provider fails for any
# reason, the app falls back to mock prices for the rest of the session — see
# src/lib/market-data/resilient-market-data-provider.ts. Live quotes only, as of Maintenance
# 1.11.2 — Finnhub's historical daily-candle endpoint is no longer selected for anything; see
# ALPHA_VANTAGE_API_KEY below for real historical candles.
NEXT_PUBLIC_MARKET_DATA_PROVIDER=
NEXT_PUBLIC_MARKET_DATA_API_KEY=

# Alpha Vantage historical market data (optional — Maintenance 1.11.2; not required to run the
# browser app; only used by the VPS worker, `npm run worker`)
#
# Real daily OHLCV candles for the app's five-symbol universe (AAPL, MSFT, NVDA, TSLA, SPY),
# replacing Finnhub as this app's historical data source. Deliberately NOT prefixed with
# NEXT_PUBLIC_ — this key must never reach the browser bundle. Only read by
# src/lib/market-data/get-server-historical-market-data-provider.ts, which is marked "server-only"
# (the build fails if a client component ever imports it, even transitively) — the browser's own
# manual Bot Scan always uses mock historical candles regardless of this setting; only scans the
# VPS worker runs use real Alpha Vantage data. Candles are cached on disk per symbol for 24 hours
# (.data/alpha-vantage-historical-cache.json, reloaded on worker restart), so a normal day of
# 15/30/60-minute scans makes at most one Alpha Vantage request per symbol, not one per scan. Get a
# free key at https://www.alphavantage.co/support/#api-key. See
# docs/product/MAINTENANCE-1.11.2-REAL-MARKET-DATA.md for the full design and verification.
ALPHA_VANTAGE_API_KEY=

# Hermes Execution MVP Phase 1 (optional — not required to run this app; only used by the
# standalone `npm run execution:demo` CLI and the "Hermes Strategy Registry" panel on
# /system-health; see docs/execution-mvp-phase-1.md)
#
# HERMES_STRATEGY_REGISTRY_PATH must be an absolute path to a Hermes Lab strategy-registry/
# directory (e.g. /path/to/hermes-lab/strategy-registry). Unset means "not configured" — a
# distinct, clearly-reported state from "configured but the registry happens to be empty."
# Read-only: nothing under this path is ever written to.
HERMES_STRATEGY_REGISTRY_PATH=

# Only "paper" is supported. Defaults to "paper" when unset; any other value (there is no "live"
# yet) fails closed at startup rather than falling back to anything.
EXECUTION_MODE=

# Defaults to false. Must be explicitly "true" to load the DEMO_ONLY fixture strategy
# (src/lib/hermes-execution/demo-strategy.ts) — it never loads otherwise, and is never written
# into, or read from, the Hermes Strategy Registry regardless of this setting.
DEMO_EXECUTION_MODE=

# Virtual starting cash for the local paper broker. Defaults to 10000 when unset.
HERMES_PAPER_STARTING_CASH=

# Maximum simultaneous open paper positions the risk engine allows. Defaults to 5 when unset.
HERMES_MAX_OPEN_POSITIONS=

# Hyperliquid Testnet Adapter Phase 1 (optional — not required to run this app; only used by
# `npm run broker:testnet-smoke` and, if BROKER_PROVIDER=hyperliquid-testnet, by anything that
# calls src/lib/hermes-execution/broker-factory.ts's getBroker(); see
# docs/hyperliquid-testnet-adapter-phase-1.md)
#
# Which broker backs the execution pipeline. Defaults to "local" (LocalPaperBroker, unchanged from
# Execution MVP Phase 1) — this is the only supported default and the only broker any autonomous
# strategy replay uses. "hyperliquid-testnet" selects HyperliquidTestnetBroker instead. There is no
# "mainnet" or "live" value; requesting one fails closed at startup, it does not fall back to
# "local". One of: local, hyperliquid-testnet.
BROKER_PROVIDER=

# Milestone 5 — Live Market Data Integration (optional — not required to run this app). Selects
# which MarketDataProvider (src/lib/hermes-execution/market-data/) backs the Milestone 2-4 pipeline
# (market-decide.ts): "mock" (MockMarketDataProvider, deterministic synthetic candles/bid/ask, no
# network) or "live" (LiveMarketDataProvider, real bid/ask from the connected broker's own
# getRate()). Defaults to "mock" so tests and any run without explicit configuration stay
# deterministic. Distinct from the unrelated NEXT_PUBLIC_MARKET_DATA_PROVIDER above (a client-
# exposed display label for the market-intelligence page's own quote widget) — same words,
# different pipelines. One of: mock, live.
HERMES_MARKET_DATA_PROVIDER=

# Placeholder only — never put a real private key in this file or in any committed file.
# 0x-prefixed, 64 hex characters (32 bytes). Required (paired with the address below) only when
# BROKER_PROVIDER=hyperliquid-testnet; validated for shape at startup, never logged, and never
# included in any audit event this pipeline records. Use a dedicated Hyperliquid TESTNET wallet
# funded with testnet-only assets — never a wallet holding anything of real value.
HYPERLIQUID_TESTNET_PRIVATE_KEY=

# Placeholder only. 0x-prefixed, 40 hex characters (20 bytes) — the account whose state is queried
# (clearinghouseState/userFills). Required (paired with the key above) only when
# BROKER_PROVIDER=hyperliquid-testnet.
HYPERLIQUID_TESTNET_ACCOUNT_ADDRESS=

# A second, independent gate on top of BROKER_PROVIDER=hyperliquid-testnet — both must be true
# before HyperliquidTestnetBroker will ever submit a real (testnet) order. Defaults to false.
HYPERLIQUID_TESTNET_EXECUTION_ENABLED=

# Upper bound (USD notional) the adapter will ever size a single test order to. Defaults to 15 —
# comfortably above Hyperliquid's own $10 minimum order notional, while staying the smallest
# practical test size. Rejected below 10 (an order that small could never be placed at all).
HYPERLIQUID_TESTNET_MAX_ORDER_VALUE_USD=

# The perp the smoke test trades. Defaults to "BTC" (a liquid, always-listed instrument).
HYPERLIQUID_TESTNET_INSTRUMENT=

# Trading212 Demo Adapter Phase 1 (optional — not required to run this app; only used by
# `npm run broker:trading212-smoke` and, if BROKER_PROVIDER=trading212-demo, by
# src/lib/hermes-execution/broker-factory.ts's getBroker(); see
# docs/trading212-demo-adapter-phase-1.md)
#
# Placeholders only — never put real credentials in this file or in any committed file. Per
# Trading212's current official auth docs (docs.trading212.com/api/section/authentication),
# credentials are an API Key + API Secret PAIR, sent as an HTTP Basic Authorization header:
# "Basic " + base64(API_KEY:API_SECRET) — not a single raw key. Generate both in the Trading212
# app under Settings -> API (Beta), for a PRACTICE/DEMO account (the Secret is shown only once at
# generation time — store it immediately). Both required only when BROKER_PROVIDER=trading212-demo;
# neither is ever logged, or included in any audit event this pipeline records. This adapter only
# ever talks to https://demo.trading212.com — there is no TRADING212_LIVE_* variable anywhere in
# this codebase.
TRADING212_API_KEY=
TRADING212_API_SECRET=

# A second, independent gate on top of BROKER_PROVIDER=trading212-demo — both must be true before
# Trading212DemoBroker will ever submit a real (demo) order. Defaults to false.
TRADING212_DEMO_EXECUTION_ENABLED=

# The equity ticker (Trading212's own identifier, e.g. "AAPL_US_EQ") the smoke test trades.
# Defaults to "AAPL_US_EQ".
TRADING212_DEMO_INSTRUMENT=

# The quantity the smoke test buys/sells. Trading212's real metadata response has no minimum-
# order-quantity field despite the OpenAPI spec documenting one (confirmed against the live API —
# see docs/trading212-demo-adapter-phase-1.md), so this is an explicit value rather than something
# derived from instrument metadata. Must be a positive number. Defaults to 1 (one share).
TRADING212_DEMO_TEST_QUANTITY=

# eToro Demo Adapter Phase 1 (optional — not required to run this app; only used by
# `npm run broker:etoro-smoke` and, if BROKER_PROVIDER=etoro-demo, by
# src/lib/hermes-execution/broker-factory.ts's getBroker(); see docs/etoro-demo-adapter-phase-1.md)
#
# Placeholders only — never put real credentials in this file or in any committed file. Generate
# both an API key and a User key from the eToro API Portal (api-portal.etoro.com) under
# Settings -> Trading -> API Key Management. Both required only when BROKER_PROVIDER=etoro-demo;
# neither is ever logged, or included in any audit event this pipeline records.
ETORO_API_KEY=
ETORO_USER_KEY=

# Must be exactly "demo" for EtoroDemoBroker to ever be constructed — a second, independent gate
# on top of BROKER_PROVIDER=etoro-demo (mirroring the other two adapters' EXECUTION_ENABLED
# flags). There is no "live"/"real" value this can be set to anywhere in this codebase; an unset
# value is never inferred as "demo".
ETORO_ENV=

# A human-readable symbol or search term (e.g. "BTC") resolved through eToro's own instrument-
# search endpoint at runtime — never a hard-coded instrumentId. Defaults to "BTC" (a crypto CFD,
# generally tradable around the clock, unlike an equity CFD bound to its underlying exchange's
# hours).
ETORO_DEMO_TEST_INSTRUMENT=

# The CFD notional amount (in USD) the smoke test's order opens. eToro's API documents no
# confirmed minimum-order-size signal to derive a safe default from (see
# docs/etoro-demo-adapter-phase-1.md), so — unlike Trading212's equivalent — there is NO default:
# this must be set explicitly whenever BROKER_PROVIDER=etoro-demo, or config-build fails closed.
# Must be a positive number.
ETORO_DEMO_TEST_AMOUNT=

# Market screening rollout stage (optional — Sprint 295; not required to run this app; only used by
# the VPS worker, `npm run worker`)
#
# Defaults to "off" if unset — the worker's traded instrument list is unconditionally the static
# five-symbol mock list regardless of this value in Sprint 295, since no liquidity data provider is
# approved yet (Sprint 293 blocked adoption pending licensing clarification) and no rollout stage
# beyond "off" has any implemented behaviour yet (Sprint 294 designed, but did not build, Shadow/
# Staged/Full — see src/lib/market-screening/resolve-market-screening-shortlist.ts). One of: off,
# shadow, staged, full. Any other value fails validation loudly at startup rather than being
# silently ignored. Not to be confused with Hermes Agent (the platform's separate AI reasoning
# layer, per the Project Constitution) — this is a deterministic candidate-narrowing service.
MARKET_SCREENING_ROLLOUT_STAGE=

# Research Import (optional — Phase 2; not required to run this app; only used by the standalone
# `npm run import-research-run -- <run-id>` CLI, never by the Next.js app itself)
#
# Where the importer looks for `<run-id>/{run.json, hypothesis.md, comparison.md, strategy-v1.py,
# strategy-v2.py, results-v1.json, results-v2.json, evidence/}` — the completed-research-run
# contract produced by the separate Hermes Lab project. Defaults to a `research-runs` folder at
# the repo root if unset. See src/lib/research-import/ for validation (required files, checksums,
# schema) and supabase/migrations/0021_research_runs.sql for the storage schema.
RESEARCH_RUNS_DIRECTORY=
