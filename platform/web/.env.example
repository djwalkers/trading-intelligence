# Supabase (optional — not required to run this app)
#
# As of Build 0.9.0, setting these switches paper trade persistence from local browser storage to
# a real Supabase project. As of Build 1.1.0, setting these ALSO turns on Supabase Auth and gates
# every page in the app behind sign-in — paper trades become scoped to the signed-in user via
# Row Level Security. See docs/database/SUPABASE-SETUP.md for setup steps (including two new
# migrations, 0006 and 0007, required for user-scoped trades) and docs/product/BUILD-1.1.0.md for
# what changed.
#
# To try this out: copy this file to .env.local and fill in values from your Supabase project
# settings (Settings -> API), then run ALL SEVEN migrations in supabase/migrations/ (not just the
# first five from Build 0.7.0). System Health will then show "Auth: Enabled" and prompt you to
# sign up / sign in.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (optional — not required to run the browser app; required to run the
# Mission 8 worker, `npm run worker`)
#
# Prepared as unused infrastructure in Mission 6; as of Mission 8, this is what the background
# worker (`npm run worker`, src/worker/) actually uses to read schedules and write scans on a
# user's behalf without a browser session. The browser app never reads this key. Deliberately NOT
# prefixed with NEXT_PUBLIC_, so Next.js never inlines it into the browser bundle; only read by
# src/lib/supabase/service-role-client.ts, which is marked "server-only" so importing it from a
# client component fails the build. This key bypasses Row Level Security entirely — see
# docs/product/MISSION-6-SERVER-ARCHITECTURE-PREPARATION.md, "Service-role safety", and
# docs/product/MISSION-8-VPS-WORKER.md, "Authentication", before running the worker against a real
# project. Get it from your Supabase project settings (Settings -> API -> service_role secret) —
# never commit it, never share it in a browser context, never log it.
SUPABASE_SERVICE_ROLE_KEY=

# Worker poll interval, in milliseconds (optional — Mission 8; defaults to 30000 / 30 seconds if
# unset). How often `npm run worker` wakes up to check for due schedules — not the scan interval
# itself (that's bot_schedules.interval_minutes, per user). Only relevant when running the worker.
WORKER_POLL_INTERVAL_MS=

# Market data (optional — not required to run this app)
#
# As of Build 1.0.0, setting both of these switches instrument pricing from mock data to a live
# external provider. Without them, the app runs entirely on mock prices — this is the default and
# fully supported. See docs/product/BUILD-1.0.0.md for the provider architecture.
#
# NEXT_PUBLIC_MARKET_DATA_PROVIDER is a label only (e.g. "Finnhub") shown in System Health and the
# Dashboard Market Data Status card — it does not select between multiple vendor integrations.
# NEXT_PUBLIC_MARKET_DATA_API_KEY is sent to Finnhub's public quote endpoint
# (https://finnhub.io/docs/api/quote), the concrete adapter implemented in
# src/lib/market-data/external-market-data-provider.ts. If the external provider fails for any
# reason, the app falls back to mock prices for the rest of the session — see
# src/lib/market-data/resilient-market-data-provider.ts. Live quotes only, as of Maintenance
# 1.11.2 — Finnhub's historical daily-candle endpoint is no longer selected for anything; see
# ALPHA_VANTAGE_API_KEY below for real historical candles.
NEXT_PUBLIC_MARKET_DATA_PROVIDER=
NEXT_PUBLIC_MARKET_DATA_API_KEY=

# Alpha Vantage historical market data (optional — Maintenance 1.11.2; not required to run the
# browser app; only used by the VPS worker, `npm run worker`)
#
# Real daily OHLCV candles for the app's five-symbol universe (AAPL, MSFT, NVDA, TSLA, SPY),
# replacing Finnhub as this app's historical data source. Deliberately NOT prefixed with
# NEXT_PUBLIC_ — this key must never reach the browser bundle. Only read by
# src/lib/market-data/get-server-historical-market-data-provider.ts, which is marked "server-only"
# (the build fails if a client component ever imports it, even transitively) — the browser's own
# manual Bot Scan always uses mock historical candles regardless of this setting; only scans the
# VPS worker runs use real Alpha Vantage data. Candles are cached on disk per symbol for 24 hours
# (.data/alpha-vantage-historical-cache.json, reloaded on worker restart), so a normal day of
# 15/30/60-minute scans makes at most one Alpha Vantage request per symbol, not one per scan. Get a
# free key at https://www.alphavantage.co/support/#api-key. See
# docs/product/MAINTENANCE-1.11.2-REAL-MARKET-DATA.md for the full design and verification.
ALPHA_VANTAGE_API_KEY=
