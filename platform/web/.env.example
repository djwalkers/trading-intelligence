# Supabase (optional — not required to run this app)
#
# As of Build 0.9.0, setting these switches paper trade persistence from local browser storage to
# a real Supabase project. As of Build 1.1.0, setting these ALSO turns on Supabase Auth and gates
# every page in the app behind sign-in — paper trades become scoped to the signed-in user via
# Row Level Security. See docs/database/SUPABASE-SETUP.md for setup steps (including two new
# migrations, 0006 and 0007, required for user-scoped trades) and docs/product/BUILD-1.1.0.md for
# what changed.
#
# To try this out: copy this file to .env.local and fill in values from your Supabase project
# settings (Settings -> API), then run ALL SEVEN migrations in supabase/migrations/ (not just the
# first five from Build 0.7.0). System Health will then show "Auth: Enabled" and prompt you to
# sign up / sign in.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Market data (optional — not required to run this app)
#
# As of Build 1.0.0, setting both of these switches instrument pricing from mock data to a live
# external provider. Without them, the app runs entirely on mock prices — this is the default and
# fully supported. See docs/product/BUILD-1.0.0.md for the provider architecture.
#
# NEXT_PUBLIC_MARKET_DATA_PROVIDER is a label only (e.g. "Finnhub") shown in System Health and the
# Dashboard Market Data Status card — it does not select between multiple vendor integrations.
# NEXT_PUBLIC_MARKET_DATA_API_KEY is sent to Finnhub's public quote endpoint
# (https://finnhub.io/docs/api/quote), the concrete adapter implemented in
# src/lib/market-data/external-market-data-provider.ts. If the external provider fails for any
# reason, the app falls back to mock prices for the rest of the session — see
# src/lib/market-data/resilient-market-data-provider.ts.
NEXT_PUBLIC_MARKET_DATA_PROVIDER=
NEXT_PUBLIC_MARKET_DATA_API_KEY=
