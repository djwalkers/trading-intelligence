# Supabase (optional — not required to run this app)
#
# This prototype uses local browser storage for paper trades by default, regardless of whether
# these variables are set. Setting them does not switch persistence to Supabase yet — see
# docs/database/SUPABASE-PERSISTENCE-PLAN.md for the planned schema and rollout.
#
# To try this out: copy this file to .env.local and fill in values from your Supabase project
# settings. System Health will then show "Supabase: Configured".
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
